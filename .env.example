# Public site URL (Open Graph / canonical). Optional locally; set in production.
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Mapbox — map, geocoding fallback, site editor (public token)
NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenAI — structured analysis, planning brief, scenario comparison, chat fallback (server only)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: Overpass API base (default: overpass-api.de)
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Optional: Created upstream for generic chat (project chat adds system context server-side)
# CREATED_CHAT_API_URL=https://chat-z.created.app/api/chat

# Supabase — required for auth, Postgres, Storage (projects, files, analysis, briefs, chat)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: for admin scripts or service operations bypassing RLS (keep secret)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: max upload bytes for project file registration (default 15MB)
# MAX_UPLOAD_BYTES=15728640

# Optional: feature flags or internal JSON (future use)
# FEATURE_FLAGS=
