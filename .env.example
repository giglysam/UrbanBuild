# Public site URL for canonical / Open Graph (set in Vercel to your deployment URL)
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Mapbox (map + optional forward geocoding fallback) — never commit real tokens
NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenAI — server only (site analysis, brief; not used for chat)
OPENAI_API_KEY=

# Optional: override default Created app chat endpoint
# CREATED_CHAT_API_URL=https://chat-z.created.app/api/chat

# Optional: Supabase for saved studies (future)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
